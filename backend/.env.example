# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Optional LLM fallback (used only when rules confidence < 0.6) ---
# Leave LLM_PROVIDER unset to disable the LLM fallback entirely.
# Supported values (case-insensitive):
#   - openai  : OpenAI-style /v1/chat/completions
#   - groq    : OpenAI-compatible Groq endpoint
#   - google  : Google Gemini generateContent (API key via ?key=)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=