{
  "name": "convergence-mock-sust",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Ticket Sorter — Express API + Vite/React client (PERN-style, no DB)",
  "workspaces": [
    "api",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:client",
    "dev:api": "npm --workspace api run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace api run build && npm --workspace client run build",
    "test": "npm --workspace api test",
    "lint": "npm --workspace api run lint",
    "start": "npm --workspace api run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
