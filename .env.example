# --- API server ---
# Render / Railway / Fly inject PORT automatically; default 3001 locally.
PORT=3001

# Comma-separated list of origins allowed to call the API (CORS).
# Use "*" for fully open, or e.g. "https://crm-ticket-sorter-client.onrender.com"
CLIENT_ORIGIN=*

# --- Optional LLM fallback (Gemini) ---
# If unset, the API runs rules-only. If set and the rules confidence is below
# CONFIDENCE_FLOOR, the API may call Gemini to refine the classification.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Below this confidence the API may consult the LLM (0..1).
CONFIDENCE_FLOOR=0.5

# Max latency for the LLM call in ms before silently falling back to rules.
LLM_TIMEOUT_MS=8000
